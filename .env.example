# Sao chép file này thành .env rồi điền giá trị thật.

# SQLite (đường dẫn tương đối tới thư mục prisma/)
DATABASE_URL="file:./dev.db"

# AI (Gemini) — lấy free tại https://aistudio.google.com/apikey
AI_API_KEY=
# Tùy chọn, mặc định gemini-2.5-flash
AI_MODEL=gemini-2.5-flash

# ───────── Thông báo Discord (mục 13) ─────────
# Webhook URL của kênh Discord. Có thể dán trực tiếp trong trang /notifications
# (lưu vào DB) — biến môi trường này chỉ là fallback nếu DB chưa có.
DISCORD_WEBHOOK_URL=
# Secret để bảo vệ endpoint /api/notify/run khi gọi từ bên ngoài
# (Windows Task Scheduler / cron / GitHub Actions). Để trống = endpoint tắt.
NOTIFY_SECRET=

# ───────── MCP server (mục 15) ─────────
# Bearer token bảo vệ /api/mcp (Claude đọc/ghi dữ liệu qua MCP). Để trống = endpoint tắt.
MCP_AUTH_TOKEN=
# Múi giờ quy "ngày địa phương" cho các field DateTime của MCP (scheduledFor, dueDate).
DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
