generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  done        Boolean   @default(false)
  emotion     String? // "love" | "meh" | "hard" | null
  date        String // the day the task is attached to, format "YYYY-MM-DD"
  carriedFrom String? // if carried over from a previous day, store the original date
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  // a task may serve a plan (section 10) — optional so ordinary task CRUD is unchanged
  planId      String?
  milestoneId String?
  plan        Plan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  // task breakdown (section 11): a parent task with ≥1 child is a "container", not counted in stats/streak
  parentId    String?
  parent      Task?      @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]     @relation("Subtasks")

  // implementation intention (section 11): "when/where" hint to do it — optional
  cue         String?

  // 80/20 (section 11): impact level "high" | "medium" | "low" — inferred by AI or set by the user
  impact      String?
  // slip reason (section 11): "tired" | "too_hard" | "no_time" | "unclear" | "deprioritized"
  slipReason  String?

  // learning duration/energy (section 14): deep-focus tasks → AI prioritizes morning slots
  deepWork     Boolean @default(false)
  // one-tap on completion: "faster" | "asExpected" | "slower" — AI calibrates the estimate, no judgment
  actualBucket String?

  // ── Generic planning fields for MCP (section 15) — ALL optional, kept in sync with the legacy fields in
  //    lib/mcp/repository. Do NOT change/remove the legacy fields; the current app runs intact.
  description      String? // long description (MCP) — the app currently only uses title; optional
  status           String? // "TODO" | "IN_PROGRESS" | "DONE" | "CANCELLED" (synced with `done`)
  priority         String? // "LOW" | "MEDIUM" | "HIGH" | "URGENT" (parallel to `impact`)
  dueDate          DateTime? // deadline (constraint), DIFFERENT from scheduledFor
  scheduledFor     DateTime? // planned time to do it (timed schedule); set together with `date` = local day
  estimatedMinutes Int? // duration estimate → compute workload/day
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags             Tag[] // implicit m-n relation (SQLite has no String[])

  // Indexes for the hot query shapes (every page filters Task by date and/or done; containers by parentId).
  // The compound (done, date) also serves bare `done` filters via its leftmost prefix.
  @@index([date])
  @@index([done, date])
  @@index([parentId])
}

// Generic "phase plan" created by MCP/Claude (section 15) — SEPARATE from Plan (the app's AI roadmap).
model Project {
  id            String    @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime?
  targetEndDate DateTime?
  status        String    @default("active") // active | done | archived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tasks         Task[]
}

// Free-form classification label (section 15) — m-n relation with Task
model Tag {
  id    String @id @default(cuid())
  name  String @unique
  tasks Task[]
}

// Long-term plan (section 10) — rolling roadmap, AI feeds daily tasks following real velocity
model Plan {
  id         String      @id @default(cuid())
  title      String
  goal       String // definition of "done" + context
  startDate  String // "YYYY-MM-DD"
  endDate    String // target date
  status     String      @default("active") // active | paused | done | archived
  intensity  String      @default("vừa") // nhẹ | vừa | dồn — soft hint for the AI
  createdAt  DateTime    @default(now())
  milestones Milestone[]
  tasks      Task[]
}

// Milestone in a plan's roadmap — progress computed DYNAMICALLY, only the done flag is stored
model Milestone {
  id         String  @id @default(cuid())
  planId     String
  plan       Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  title      String
  order      Int // order in the roadmap
  targetDate String?
  done       Boolean @default(false)
  tasks      Task[]
}

model DailyNote {
  id   String @id @default(cuid())
  date String @unique // "YYYY-MM-DD"
  note String // the user's end-of-day note
}

// Schedule (section 14): HARD schedule repeating weekly (study, work). NOT a Task —
// it is CONTEXT feeding the suggestion engine (real free-time budget), not counted in streak/stats.
model Commitment {
  id         String   @id @default(cuid())
  title      String
  dayOfWeek  Int // 0=Sun .. 6=Sat (matches Date.getDay)
  startTime  String // "HH:MM" local time
  endTime    String
  kind       String   @default("khac") // "hoc" | "lam" | "khac"
  active     Boolean  @default(true)
  validFrom  String? // term validity window (section 14) — auto-expires; null = always
  validUntil String?
  weekParity String? // null = every week | "odd" | "even" (odd/even week of the term)
  createdAt  DateTime @default(now())

  @@index([dayOfWeek])
}

// Schedule configuration (section 14, upgrade): 1 singleton row — wake/sleep times + buffer + slot threshold.
// Used to compute the DYNAMIC free-time budget (computeFreeSlots) instead of a hardcoded 07–23h. Every field has a default.
model ScheduleSettings {
  id               String   @id @default("singleton")
  wakeTime         String   @default("07:00")
  sleepTime        String   @default("23:00")
  bufferMin        Int      @default(15) // buffer before/after each hard schedule item (travel/break)
  minSlotMin       Int      @default(30) // drop free slots shorter than this threshold
  termAnchorMonday String? // the Monday anchor to compute odd/even weeks (section 14, term) — optional
  updatedAt        DateTime @updatedAt
}

// SOFT time block repeating weekly (time-blocking, section 14): "study 20–22h", MOVABLE — unlike a hard schedule.
// NOT subtracted from the HARD free-time budget; only reduces the "suggestion budget" the AI uses (softLoad). No completion.
model SoftBlock {
  id         String   @id @default(cuid())
  title      String
  dayOfWeek  Int // 0=Sun .. 6=Sat
  startTime  String // "HH:MM"
  endTime    String
  kind       String   @default("focus") // focus | hoc | lam | khac
  active     Boolean  @default(true)
  validFrom  String? // term validity window (section 14, Phase 3) — optional
  validUntil String?
  weekParity String? // null = every week | "odd" | "even"
  createdAt  DateTime @default(now())

  @@index([dayOfWeek])
}

// One-off AD-HOC event on a specific day; or cancels=true = "off all day"
// (skip all hard schedule items that day). startTime null = all-day event.
model ScheduleEvent {
  id        String  @id @default(cuid())
  title     String
  date      String // "YYYY-MM-DD"
  startTime String?
  endTime   String?
  kind      String  @default("khac")
  cancels   Boolean @default(false)

  @@index([date])
}

// Discord notifications (section 13): 1-row config (single-user app) — webhook + intensity +
// enable/disable + per-kind times + quiet hours + AI content. Every field optional/low-friction (section 11.1).
model NotificationSettings {
  id               String  @id @default("singleton")
  enabled          Boolean @default(false) // master switch — off by default until a webhook is pasted
  discordWebhookUrl String?
  intensity        String  @default("balanced") // minimal | balanced | active (intensity preset)

  morningEnabled    Boolean @default(true)
  morningTime       String  @default("07:30") // "HH:MM" local time (server TZ)
  streakGuardEnabled Boolean @default(true)
  streakGuardTime   String  @default("20:00")
  randomNudgeEnabled Boolean @default(true)
  eveningEnabled    Boolean @default(false)
  eveningTime       String  @default("21:30")
  // "Incubating" (section 17): gentle reminder to pull a goal out when free-time budget is high — shares the randomWindow window
  queueNudgeEnabled Boolean @default(true)

  // window for the random nudge + quiet hours (send nothing during this range)
  randomWindowStart String @default("09:00")
  randomWindowEnd   String @default("18:00")
  quietStart        String @default("22:00")
  quietEnd          String @default("07:00")

  // AI-written content — toggle each part
  includeMotivation Boolean @default(true)
  includeQuote      Boolean @default(true)
  includeTip        Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// Send log (section 13): idempotency (1 time/kind/day), history for the UI, and to help the AI avoid repeating lines.
model NotificationLog {
  id     String   @id @default(cuid())
  kind   String // morning | streak_guard | random_nudge | evening
  date   String // "YYYY-MM-DD" — idempotency key together with kind
  status String // sent | skipped | error
  detail String? // preview of the content sent / reason for skipping / error message
  sentAt DateTime @default(now())

  @@index([kind, date])
  @@index([sentAt])
}

// Habit (section 11): one-tap repeating behavior. NO points/hard-streak — streak inferred DYNAMICALLY from HabitCheck.
// Isolated from Task: not counted in the task stats/streak/completion.
model Habit {
  id         String       @id @default(cuid())
  title      String
  daysOfWeek String? // CSV "1,2,3,4,5" (0=Sun..6=Sat); null = daily
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  checks     HabitCheck[]
}

// One habit tick in a day — idempotent on (habitId, date)
model HabitCheck {
  id      String @id @default(cuid())
  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date    String // "YYYY-MM-DD"

  @@unique([habitId, date])
  @@index([date])
}

// Personal OS (section 11): structured in-day check-in — ALL optional, skippable.
// Used to infer dynamic "capacity" (energy/day); the AI lightens the load / suggests a recovery day when energy is low.
model DayCheckin {
  id         String @id @default(cuid())
  date       String @unique // "YYYY-MM-DD"
  energy     Int? // 1..5
  mood       Int? // 1..5
  stress     Int? // 1..5
  sleepHours Float?
}

// "Incubating" (section 17): queue of UNCOMMITTED goals — the pre-task/pre-plan stage (Someday/Maybe).
// NO `date`, NOT counted in streak/stats/completion (isolated like Plan/Habit). Age/staleness inferred
// DYNAMICALLY in lib/queue.ts. Exits: drag into a Task (promotedTaskId) or promote into a Plan (promotedPlanId).
model Goal {
  id             String    @id @default(cuid())
  title          String
  note           String? // context / why it's wanted (optional)
  status         String    @default("incubating") // incubating | promoted | dropped
  pinned         Boolean   @default(false) // user marks "want to do soon" → reset staleness
  snoozedUntil   String? // "YYYY-MM-DD" — no nudge/no staleness prompt before this date
  lastNudgedAt   DateTime? // throttle nudge frequency (don't repeat one goal back to back)
  promotedPlanId String? // backtrace: which plan it was promoted into
  promotedTaskId String? // backtrace: which task it was dragged into
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}
