generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  done        Boolean   @default(false)
  emotion     String? // "love" | "meh" | "hard" | null
  date        String // ngày gắn task, dạng "YYYY-MM-DD"
  carriedFrom String? // nếu được carry-over từ ngày trước, lưu ngày gốc
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  // task có thể phục vụ một kế hoạch (mục 10) — optional để CRUD task thường không đổi
  planId      String?
  milestoneId String?
  plan        Plan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  // chia nhỏ task (mục 11): task cha có ≥1 con là "container", không tính vào stats/streak
  parentId    String?
  parent      Task?      @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]     @relation("Subtasks")

  // implementation intention (mục 11): gợi ý "khi nào/ở đâu" làm việc — tùy chọn
  cue         String?

  // 80/20 (mục 11): mức tác động "high" | "medium" | "low" — AI suy hoặc người dùng đặt
  impact      String?
  // lý do trượt (mục 11): "tired" | "too_hard" | "no_time" | "unclear" | "deprioritized"
  slipReason  String?

  // ── Field lập kế hoạch generic cho MCP (mục 15) — TẤT CẢ optional, đồng bộ với field cũ ở
  //    lib/mcp/repository. KHÔNG đổi/xoá field cũ; app hiện tại chạy nguyên vẹn.
  description      String? // mô tả dài (MCP) — app hiện chỉ dùng title; optional
  status           String? // "TODO" | "IN_PROGRESS" | "DONE" | "CANCELLED" (đồng bộ với `done`)
  priority         String? // "LOW" | "MEDIUM" | "HIGH" | "URGENT" (song song `impact`)
  dueDate          DateTime? // hạn chót (ràng buộc), KHÁC scheduledFor
  scheduledFor     DateTime? // mốc dự kiến làm (lịch theo giờ); set kèm `date` = ngày địa phương
  estimatedMinutes Int? // ước lượng thời lượng → tính workload/ngày
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags             Tag[] // quan hệ m-n ngầm (SQLite không có String[])
}

// "Kế hoạch giai đoạn" generic do MCP/Claude tạo (mục 15) — RIÊNG với Plan (roadmap AI của app).
model Project {
  id            String    @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime?
  targetEndDate DateTime?
  status        String    @default("active") // active | done | archived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tasks         Task[]
}

// Nhãn phân loại tự do (mục 15) — quan hệ m-n với Task
model Tag {
  id    String @id @default(cuid())
  name  String @unique
  tasks Task[]
}

// Kế hoạch dài hạn (mục 10) — roadmap cuốn chiếu, AI rót task hằng ngày bám tốc độ thật
model Plan {
  id         String      @id @default(cuid())
  title      String
  goal       String // định nghĩa "xong" + bối cảnh
  startDate  String // "YYYY-MM-DD"
  endDate    String // mốc mục tiêu
  status     String      @default("active") // active | paused | done | archived
  intensity  String      @default("vừa") // nhẹ | vừa | dồn — gợi ý mềm cho AI
  createdAt  DateTime    @default(now())
  milestones Milestone[]
  tasks      Task[]
}

// Cột mốc trong roadmap của một plan — tiến độ tính ĐỘNG, chỉ lưu cờ done
model Milestone {
  id         String  @id @default(cuid())
  planId     String
  plan       Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  title      String
  order      Int // thứ tự trong roadmap
  targetDate String?
  done       Boolean @default(false)
  tasks      Task[]
}

model DailyNote {
  id   String @id @default(cuid())
  date String @unique // "YYYY-MM-DD"
  note String // ghi chú cuối ngày của người dùng
}

// Lịch trình (mục 14): lịch CỨNG lặp theo tuần (học, làm). KHÔNG phải Task —
// là BỐI CẢNH nuôi bộ máy đề xuất (quỹ giờ rảnh thật), không tính vào streak/stats.
model Commitment {
  id        String   @id @default(cuid())
  title     String
  dayOfWeek Int // 0=CN .. 6=T7 (khớp Date.getDay)
  startTime String // "HH:MM" giờ địa phương
  endTime   String
  kind      String   @default("khac") // "hoc" | "lam" | "khac"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([dayOfWeek])
}

// Cấu hình lịch trình (mục 14, nâng cấp): 1 hàng singleton — giờ thức/ngủ + buffer + ngưỡng khe.
// Dùng để tính quỹ giờ rảnh ĐỘNG (computeFreeSlots) thay cho hằng số 07–23h cứng. Mọi field có default.
model ScheduleSettings {
  id               String   @id @default("singleton")
  wakeTime         String   @default("07:00")
  sleepTime        String   @default("23:00")
  bufferMin        Int      @default(15) // đệm trước/sau mỗi lịch cứng (di chuyển/nghỉ)
  minSlotMin       Int      @default(30) // bỏ khe trống ngắn hơn ngưỡng này
  termAnchorMonday String? // mốc thứ 2 để tính tuần chẵn/lẻ (mục 14, kỳ học) — tùy chọn
  updatedAt        DateTime @updatedAt
}

// Khung giờ MỀM lặp theo tuần (time-blocking, mục 14): "20–22h học", DỜI ĐƯỢC — khác lịch cứng.
// KHÔNG bị trừ khỏi quỹ giờ rảnh CỨNG; chỉ giảm "quỹ gợi ý" mà AI dùng (softLoad). Không completion.
model SoftBlock {
  id         String   @id @default(cuid())
  title      String
  dayOfWeek  Int // 0=CN .. 6=T7
  startTime  String // "HH:MM"
  endTime    String
  kind       String   @default("focus") // focus | hoc | lam | khac
  active     Boolean  @default(true)
  validFrom  String? // khoảng hiệu lực kỳ học (mục 14, Pha 3) — tùy chọn
  validUntil String?
  weekParity String? // null = mọi tuần | "odd" | "even"
  createdAt  DateTime @default(now())

  @@index([dayOfWeek])
}

// Sự kiện ĐỘT XUẤT một lần theo ngày cụ thể; hoặc cancels=true = "nghỉ cả ngày"
// (bỏ qua mọi lịch cứng hôm đó). startTime null = sự kiện cả ngày.
model ScheduleEvent {
  id        String  @id @default(cuid())
  title     String
  date      String // "YYYY-MM-DD"
  startTime String?
  endTime   String?
  kind      String  @default("khac")
  cancels   Boolean @default(false)

  @@index([date])
}

// Thông báo Discord (mục 13): cấu hình 1 hàng (app một người dùng) — webhook + cường độ +
// bật/tắt + giờ từng loại + giờ yên + nội dung AI. Mọi field optional/độ ma sát thấp (mục 11.1).
model NotificationSettings {
  id               String  @id @default("singleton")
  enabled          Boolean @default(false) // công tắc tổng — mặc định tắt tới khi dán webhook
  discordWebhookUrl String?
  intensity        String  @default("balanced") // minimal | balanced | active (preset cường độ)

  morningEnabled    Boolean @default(true)
  morningTime       String  @default("07:30") // "HH:MM" giờ địa phương (TZ server)
  streakGuardEnabled Boolean @default(true)
  streakGuardTime   String  @default("20:00")
  randomNudgeEnabled Boolean @default(true)
  eveningEnabled    Boolean @default(false)
  eveningTime       String  @default("21:30")

  // cửa sổ cho cú hích ngẫu nhiên + giờ yên (không gửi gì trong khoảng này)
  randomWindowStart String @default("09:00")
  randomWindowEnd   String @default("18:00")
  quietStart        String @default("22:00")
  quietEnd          String @default("07:00")

  // nội dung do AI viết — bật/tắt từng phần
  includeMotivation Boolean @default(true)
  includeQuote      Boolean @default(true)
  includeTip        Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// Nhật ký gửi (mục 13): idempotency (1 lần/loại/ngày), lịch sử cho UI, và để AI tránh lặp câu.
model NotificationLog {
  id     String   @id @default(cuid())
  kind   String // morning | streak_guard | random_nudge | evening
  date   String // "YYYY-MM-DD" — khoá idempotency cùng kind
  status String // sent | skipped | error
  detail String? // xem trước nội dung đã gửi / lý do bỏ qua / thông báo lỗi
  sentAt DateTime @default(now())

  @@index([kind, date])
  @@index([sentAt])
}

// Personal OS (mục 11): check-in cấu trúc trong ngày — TẤT CẢ optional, bỏ qua được.
// Dùng để suy "capacity" (sức/ngày) động; AI giảm tải / đề xuất ngày phục hồi khi sức thấp.
model DayCheckin {
  id         String @id @default(cuid())
  date       String @unique // "YYYY-MM-DD"
  energy     Int? // 1..5
  mood       Int? // 1..5
  stress     Int? // 1..5
  sleepHours Float?
}
